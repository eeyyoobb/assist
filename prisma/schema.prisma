// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Report {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  company    String
  staffRole  StaffRole
  reportType ReportType
  userId     String
  userName   String

  // Relations
  socialMedia    SocialMediaReport?
  officeActivity OfficeActivityReport?

  createdAt DateTime @default(now())
}

model SocialMediaReport {
  id              String @id @default(auto()) @map("_id") @db.ObjectId
  mediaName       String
  totalPost       Int
  totalView       Int
  totalEngagement Int
  followers       Int

  report   Report @relation(fields: [reportId], references: [id])
  reportId String @unique @db.ObjectId

  // Relates back to the users involved in this report
  users   User[]   @relation(fields: [userIDs], references: [id])
  userIDs String[] @db.ObjectId
}

model OfficeActivityReport {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  task Task

  report   Report @relation(fields: [reportId], references: [id])
  reportId String @unique @db.ObjectId

  consulting ConsultingEntry[]

  // Relates back to the users involved
  users   User[]   @relation(fields: [userIDs], references: [id])
  userIDs String[] @db.ObjectId
}

model ConsultingEntry {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  phoneNumber String

  officeActivity   OfficeActivityReport @relation(fields: [officeActivityId], references: [id])
  officeActivityId String               @db.ObjectId
}

model User {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  telegramId BigInt     @unique
  name       String
  company    String?
  role       StaffRole?

  createdAt DateTime @default(now())

  // MongoDB Many-to-Many requires fields on both sides
  socialMediaReports   SocialMediaReport[] @relation(fields: [socialMediaReportIds], references: [id])
  socialMediaReportIds String[]            @db.ObjectId

  officeActivityReports   OfficeActivityReport[] @relation(fields: [officeActivityReportIds], references: [id])
  officeActivityReportIds String[]               @db.ObjectId
}

// Enums remain the same
enum StaffRole {
  media_manager
  sales
  assistant_manager
  manager
  admin
  auditor
  guest
}

enum ReportType {
  social_media
  office_activity
}

enum Task {
  equb
  key
}
